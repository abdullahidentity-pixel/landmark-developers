<section class="hp-philosophy section">
  <div class="hp-philosophy__inner container reveal">

    <div class="hp-philosophy__label-col">
      <span class="hp-philosophy__label">{{ section.settings.label }}</span>
    </div>

    <div class="hp-philosophy__content-col">
      {%- if section.settings.headline != blank -%}
        <h2 class="hp-philosophy__headline">{{ section.settings.headline }}</h2>
      {%- endif -%}
      <p class="hp-philosophy__body">{{ section.settings.body }}</p>
      {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
        <a href="{{ section.settings.cta_url }}" class="hp-philosophy__link">
          {{ section.settings.cta_label }} →
        </a>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "HP — Philosophy",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Left label",
      "default": "Our Philosophy"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Fewer ingredients. Clearer skin."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "We believe in precision over excess. Every Velour Skin formula is built around a single active concern — no filler, no compromise. Science-led, skin-first, always transparent about what goes in and why."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Link label",
      "default": "Read the full story"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Link URL"
    }
  ],
  "presets": [
    {
      "name": "HP — Philosophy",
      "settings": {
        "label": "Our Philosophy",
        "headline": "Fewer ingredients. Clearer skin.",
        "body": "We believe in precision over excess. Every Velour Skin formula is built around a single active concern — no filler, no compromise. Science-led, skin-first, always transparent about what goes in and why.",
        "cta_label": "Read the full story"
      }
    }
  ]
}
{% endschema %}
