<section class="newsletter section">
  <div class="container">
    <div class="newsletter__inner">

      <div class="newsletter__copy">
        {%- if section.settings.label != blank -%}
          <p class="t-label reveal">{{ section.settings.label }}</p>
        {%- endif -%}
        <h2 class="newsletter__heading reveal reveal-delay-1">
          {{ section.settings.heading_before }}
          {%- if section.settings.heading_emphasis != blank -%}
            <em>{{ section.settings.heading_emphasis }}</em>
          {%- endif -%}
        </h2>
        {%- if section.settings.subtext != blank -%}
          <p class="newsletter__sub reveal reveal-delay-2">{{ section.settings.subtext }}</p>
        {%- endif -%}
      </div>

      <div class="newsletter__form-wrap reveal reveal-delay-2">
        {%- form 'customer', id: 'newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="newsletter__form">
            <input type="email"
                   name="contact[email]"
                   id="newsletter-email"
                   placeholder="{{ section.settings.placeholder | default: 'Your email address' }}"
                   autocomplete="email"
                   required
                   aria-label="Email address for newsletter">
            <button type="submit" class="btn btn--primary">
              {{ section.settings.button_label | default: 'Subscribe' }}
            </button>
          </div>
          {%- if form.posted_successfully? -%}
            <p style="color: var(--c-green-nat); font-size: var(--text-sm); margin-top: 0.75rem;">
              ✓ {{ section.settings.success_message | default: 'Thank you for subscribing.' }}
            </p>
          {%- endif -%}
        {%- endform -%}
        <p class="newsletter__privacy">
          {{ section.settings.privacy_text | default: 'By subscribing you agree to our Privacy Policy. Unsubscribe anytime.' }}
        </p>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Join the ritual"
    },
    {
      "type": "text",
      "id": "heading_before",
      "label": "Heading — before emphasis",
      "default": "Skincare science,"
    },
    {
      "type": "text",
      "id": "heading_emphasis",
      "label": "Heading — emphasis (italic)",
      "default": "delivered to you."
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Ingredient deep dives, routine guides, and early access to new formulas. No noise."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you. Welcome to the ritual."
    },
    {
      "type": "text",
      "id": "privacy_text",
      "label": "Privacy note"
    }
  ],
  "presets": [
    { "name": "Newsletter" }
  ]
}
{% endschema %}
