    },
    { "type": "text",     "id": "avoid_eyebrow", "label": "Eyebrow",    "default": "What we leave out" },
    { "type": "textarea", "id": "avoid_heading", "label": "Heading",    "default": "Ingredients you will never find in our formulas." },
    { "type": "textarea", "id": "avoid_body",    "label": "Body text",  "default": "Our formulation brief starts with a 'never list'. If an ingredient has a poor safety profile, limited evidence, or serves only a marketing function — it doesn't make the cut." },
    {
      "type": "header",
      "content": "Formulation Process"
    },
    { "type": "text",     "id": "formulation_eyebrow", "label": "Eyebrow",    "default": "How we formulate" },
    { "type": "textarea", "id": "formulation_heading", "label": "Heading",    "default": "A rigorous process before anything reaches your skin." },
    { "type": "textarea", "id": "formulation_intro",   "label": "Intro text", "default": "Our formulation process is built around a single question: does this actually work, and is it safe? Every step exists to answer that." },
    {
      "type": "header",
      "content": "Skin Barrier"
    },
    { "type": "image_picker", "id": "barrier_image",   "label": "Image" },
