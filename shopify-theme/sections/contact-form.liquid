<section class="contact-section">
  <div class="container">
    <div class="contact-section__inner">

      <!-- Info -->
      <div class="contact-info">
        <p class="t-eyebrow reveal" style="color: var(--c-sage);">{{ section.settings.label | default: 'Get in Touch' }}</p>
        <h1 class="contact-info__title reveal reveal-delay-1">
          {{ section.settings.heading_before | default: 'We would love' }}
          <em>{{ section.settings.heading_emphasis | default: 'to hear from you.' }}</em>
        </h1>
        <p class="contact-info__body reveal reveal-delay-2">{{ section.settings.body | default: 'Whether you have a question about your skin, a formula, or our brand — our team responds within 24 hours.' }}</p>

        <div class="contact-details">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'detail' -%}
                <div class="contact-detail reveal" {{ block.shopify_attributes }}>
                  <p class="contact-detail__label">{{ block.settings.label }}</p>
                  <p class="contact-detail__value">
                    {%- if block.settings.link != blank -%}
                      <a href="{{ block.settings.link }}">{{ block.settings.value }}</a>
                    {%- else -%}
                      {{ block.settings.value }}
                    {%- endif -%}
                  </p>
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>

      <!-- Form -->
      <div class="contact-form-wrap reveal reveal-delay-2">
        <h2>{{ section.settings.form_title | default: 'Send a Message' }}</h2>

        {%- if form.posted_successfully? -%}
          <div style="padding: 1.5rem; background: var(--c-mint); border-radius: var(--r-xl); margin-bottom: 1.5rem;">
            <p style="color: var(--c-forest); font-weight: 500;">✓ {{ section.settings.success_message | default: 'Thank you. We will be in touch within 24 hours.' }}</p>
          </div>
        {%- endif -%}

        {%- form 'contact' -%}
          <div class="contact-form" data-contact-form>

            <div class="form-row">
              <div class="field">
                <label class="field__label" for="contact-name">First Name</label>
                <input class="field__input" type="text" id="contact-name" name="contact[first_name]" placeholder="Jane" required>
              </div>
              <div class="field">
                <label class="field__label" for="contact-surname">Last Name</label>
                <input class="field__input" type="text" id="contact-surname" name="contact[last_name]" placeholder="Smith">
              </div>
            </div>

            <div class="field">
              <label class="field__label" for="contact-email">Email Address</label>
              <input class="field__input" type="email" id="contact-email" name="contact[email]" placeholder="jane@example.com" autocomplete="email" required>
            </div>

            <div class="field">
              <label class="field__label" for="contact-subject">Subject</label>
              <select class="field__select" id="contact-subject" name="contact[subject]">
                <option value="">Select a topic</option>
                <option value="Skin Advice">Skin Advice</option>
                <option value="Product Question">Product Question</option>
                <option value="Order Help">Order / Shipping</option>
                <option value="Press Enquiry">Press Enquiry</option>
                <option value="Partnership">Partnership</option>
                <option value="Other">Other</option>
              </select>
            </div>

            <div class="field">
              <label class="field__label" for="contact-message">Message</label>
              <textarea class="field__textarea" id="contact-message" name="contact[body]" placeholder="Tell us what's on your mind…" required></textarea>
            </div>

            <button type="submit" class="btn btn--primary full-width" data-contact-submit>
              {{ section.settings.button_label | default: 'Send Message' }}
            </button>

          </div>
        {%- endform -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Get in Touch"
    },
    {
      "type": "text",
      "id": "heading_before",
      "label": "Heading — before emphasis",
      "default": "We would love"
    },
    {
      "type": "text",
      "id": "heading_emphasis",
      "label": "Heading — emphasis (italic)",
      "default": "to hear from you."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Intro text"
    },
    {
      "type": "text",
      "id": "form_title",
      "label": "Form title",
      "default": "Send a Message"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Send Message"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you. We'll be in touch within 24 hours."
    }
  ],
  "blocks": [
    {
      "type": "detail",
      "name": "Contact Detail",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Email" },
        { "type": "text", "id": "value", "label": "Value", "default": "hello@velourskin.com" },
        { "type": "url", "id": "link", "label": "Link (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact",
      "blocks": [
        { "type": "detail", "settings": { "label": "Email", "value": "hello@velourskin.com", "link": "mailto:hello@velourskin.com" } },
        { "type": "detail", "settings": { "label": "Response time", "value": "Within 24 hours, Mon–Fri" } },
        { "type": "detail", "settings": { "label": "Skincare Advice", "value": "Free consultation available — mention in your message" } }
      ]
    }
  ]
}
{% endschema %}
