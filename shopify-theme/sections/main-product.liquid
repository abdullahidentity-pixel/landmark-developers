<!-- ══════════════════════════════════════════════════════
     JAVASCRIPT
     ══════════════════════════════════════════════════════ -->
<script>
(function () {
  'use strict';

  /* ── 0. DATA ── */
  const variants = JSON.parse(
    document.getElementById('pd-variants-json')?.textContent || '[]'
  );
  let selectedOptions = [
    {{ current_variant.option1 | json }},
    {{ current_variant.option2 | json }},
    {{ current_variant.option3 | json }}
  ];

  /* ── 1. GALLERY ── */
  const mainImg   = document.getElementById('pd-main-img');
  const thumbBtns = document.querySelectorAll('[data-gallery-thumb]');

  function setActiveThumb(active) {
    thumbBtns.forEach(b => b.classList.toggle('is-active', b === active));
  }

  thumbBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      if (!mainImg) return;
      setActiveThumb(btn);
      mainImg.style.opacity = '0';
      mainImg.style.transform = 'scale(0.98)';
      setTimeout(() => {
        mainImg.src = btn.dataset.src;
        mainImg.alt = btn.dataset.alt || mainImg.alt;
        mainImg.style.opacity = '1';
        mainImg.style.transform = 'scale(1)';
      }, 180);
    });
  });

  /* ── 2. QUANTITY ── */
  const qtyInput = document.getElementById('pd-qty-input');

  document.getElementById('pd-qty-minus')?.addEventListener('click', () => {
    const v = parseInt(qtyInput.value, 10);
    if (v > 1) qtyInput.value = v - 1;
  });
  document.getElementById('pd-qty-plus')?.addEventListener('click', () => {
    qtyInput.value = parseInt(qtyInput.value, 10) + 1;
  });

  /* ── 3. VARIANT SELECTOR ── */
  function moneyFormat(cents) {
    const sym = {{ localization.country.currency.symbol | default: '£' | json }};
    const val = (cents / 100).toFixed(2).replace(/\.00$/, '');
    return sym + val;
  }

  function updatePriceUI(variant) {
    const priceEl  = document.getElementById('pd-price');
    const compareEl = document.getElementById('pd-compare-price');
    const saveEl   = document.getElementById('pd-save-badge');
    const atcPrice = document.getElementById('pd-atc-price');
    const stickyP  = document.getElementById('pd-sticky-price');

    if (priceEl)   priceEl.textContent   = moneyFormat(variant.price);
    if (atcPrice)  atcPrice.textContent  = moneyFormat(variant.price);
    if (stickyP)   stickyP.textContent   = moneyFormat(variant.price);

    if (variant.compare_at_price > variant.price) {
      if (compareEl) { compareEl.textContent = moneyFormat(variant.compare_at_price); compareEl.hidden = false; }
      if (saveEl)    { saveEl.textContent = 'Save ' + moneyFormat(variant.compare_at_price - variant.price); saveEl.hidden = false; }
    } else {
      if (compareEl) compareEl.hidden = true;
      if (saveEl)    saveEl.hidden    = true;
    }
  }

  function updateAvailability(variant) {
    const atcBtn  = document.getElementById('pd-atc-btn');
    const atcText = document.getElementById('pd-atc-text');
    const idInput = document.getElementById('pd-variant-id');

    if (idInput)  idInput.value = variant.id;
    if (atcBtn)   atcBtn.disabled = !variant.available;
    if (atcText)  atcText.textContent = variant.available ? 'Add to Bag' : 'Sold Out';
  }

  function updateGalleryForVariant(variant) {
    if (variant.featured_image && mainImg) {
      const newSrc = variant.featured_image.src;
      mainImg.style.opacity = '0';
      setTimeout(() => {
        mainImg.src = newSrc;
        mainImg.style.opacity = '1';
      }, 180);
      // Activate matching thumb
      thumbBtns.forEach(btn => {
        if (btn.dataset.src && btn.dataset.src.includes(newSrc.split('?')[0].split('/').pop())) {
          setActiveThumb(btn);
        }
      });
    }
  }

  function resolveVariant() {
    return variants.find(v =>
      (selectedOptions[0] == null || v.option1 === selectedOptions[0]) &&
      (selectedOptions[1] == null || v.option2 === selectedOptions[1]) &&
      (selectedOptions[2] == null || v.option3 === selectedOptions[2])
    ) || null;
  }

  document.querySelectorAll('.pd-option-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const pos = parseInt(btn.dataset.optionPos, 10) - 1;
      selectedOptions[pos] = btn.dataset.optionVal;

      // Update active button states for this option group
      document.querySelectorAll(`.pd-option-btn[data-option-pos="${pos + 1}"]`)
        .forEach(b => {
          b.classList.toggle('is-active', b === btn);
          b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
        });

      // Update selected label
      const valLabel = document.getElementById(`pd-option-val-${pos + 1}`);
      if (valLabel) valLabel.textContent = btn.dataset.optionVal;

      const variant = resolveVariant();
      if (variant) {
        updatePriceUI(variant);
        updateAvailability(variant);
        updateGalleryForVariant(variant);
      }
    });
  });

  /* ── 4. ATC — AJAX ── */
  const atcBtn   = document.getElementById('pd-atc-btn');
  const atcText  = document.getElementById('pd-atc-text');
  const atcError = document.getElementById('pd-atc-error');

  function addToCart(variantId, qty) {
    if (!atcBtn || atcBtn.disabled) return;
    const wasText = atcText?.textContent;

    atcBtn.disabled = true;
    atcBtn.classList.add('is-loading');
    if (atcText) atcText.textContent = 'Adding…';
    if (atcError) atcError.textContent = '';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: qty })
    })
    .then(r => r.json())
    .then(data => {
      atcBtn.classList.remove('is-loading');
      if (data.status) throw new Error(data.description || 'Could not add to bag.');

      atcBtn.classList.add('is-added');
      if (atcText) atcText.textContent = 'Added to Bag';
      document.dispatchEvent(new CustomEvent('cart:open'));
      document.dispatchEvent(new CustomEvent('cart:refresh'));

      setTimeout(() => {
        atcBtn.disabled = false;
        atcBtn.classList.remove('is-added');
        if (atcText) atcText.textContent = wasText || 'Add to Bag';
      }, 2400);
    })
    .catch(err => {
      atcBtn.disabled = false;
      atcBtn.classList.remove('is-loading', 'is-added');
      if (atcText) atcText.textContent = wasText || 'Add to Bag';
      if (atcError) atcError.textContent = err.message || 'Something went wrong. Please try again.';
    });
  }

  document.getElementById('pd-atc-form')?.addEventListener('submit', e => {
    e.preventDefault();
    const id  = parseInt(document.getElementById('pd-variant-id').value, 10);
    const qty = parseInt(qtyInput?.value || 1, 10);
    addToCart(id, qty);
  });

  // Mobile sticky button mirrors main ATC
  document.getElementById('pd-sticky-btn')?.addEventListener('click', () => {
    const id  = parseInt(document.getElementById('pd-variant-id').value, 10);
    const qty = parseInt(qtyInput?.value || 1, 10);
    addToCart(id, qty);
  });

  /* ── 5. MOBILE STICKY ATC VISIBILITY ── */
  const stickyBar = document.getElementById('pd-sticky-mobile');

  if (stickyBar && atcBtn && 'IntersectionObserver' in window) {
    const obs = new IntersectionObserver(entries => {
      const visible = entries[0].isIntersecting;
      stickyBar.classList.toggle('is-visible', !visible);
      stickyBar.setAttribute('aria-hidden', visible ? 'true' : 'false');
    }, {
      threshold: 0,
      rootMargin: '0px 0px -80px 0px'
    });
    obs.observe(atcBtn);
  }

  /* ── 6. FAQ ACCORDION ── */
  document.querySelectorAll('.pd-faq-item').forEach(details => {
    const summary = details.querySelector('summary');
    if (!summary) return;

    summary.addEventListener('click', e => {
      e.preventDefault();
      if (details.open) {
        // Animate close
        details.classList.add('is-closing');
        setTimeout(() => {
          details.open = false;
          details.classList.remove('is-closing');
        }, 400);
      } else {
        // Close all others
        document.querySelectorAll('.pd-faq-item[open]').forEach(open => {
          if (open !== details) {
            open.classList.add('is-closing');
            setTimeout(() => {
              open.open = false;
              open.classList.remove('is-closing');
            }, 400);
          }
        });
        details.open = true;
      }
    });
  });

})();
</script>

