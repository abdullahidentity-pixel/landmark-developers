<section class="quiz-section" data-serum-quiz>
  <div class="quiz-wrapper">

    <!-- Progress -->
    <div class="quiz-progress">
      <div class="quiz-progress__bar">
        <div class="quiz-progress__fill" data-quiz-progress style="width: 0%"></div>
      </div>
      <p class="quiz-progress__steps">Step <span data-quiz-progress-text>1 of 4</span></p>
    </div>

    <!-- Step 1: Concern -->
    <div class="quiz-step is-active" data-quiz-step="1">
      <p class="quiz-step__label">Step 1 of 4</p>
      <h2 class="quiz-step__question">What is your <em>primary skin concern</em>?</h2>
      <div class="quiz-options">
        <button class="quiz-option" data-quiz-option data-value="hydration">
          <span class="quiz-option__icon">💧</span>
          <span class="quiz-option__label">Hydration</span>
          <span class="quiz-option__desc">Tight, dry, or dehydrated skin that needs moisture</span>
        </button>
        <button class="quiz-option" data-quiz-option data-value="brightening">
          <span class="quiz-option__icon">✨</span>
          <span class="quiz-option__label">Brightening</span>
          <span class="quiz-option__desc">Dull skin, uneven tone, or dark spots</span>
        </button>
        <button class="quiz-option" data-quiz-option data-value="anti-aging">
          <span class="quiz-option__icon">🌸</span>
          <span class="quiz-option__label">Anti-aging</span>
          <span class="quiz-option__desc">Fine lines, loss of firmness, or lack of elasticity</span>
        </button>
        <button class="quiz-option" data-quiz-option data-value="pores">
          <span class="quiz-option__icon">🔬</span>
          <span class="quiz-option__label">Pores &amp; Texture</span>
          <span class="quiz-option__desc">Visible pores, rough texture, or congestion</span>
        </button>
        <button class="quiz-option" data-quiz-option data-value="sensitivity">
          <span class="quiz-option__icon">🌿</span>
          <span class="quiz-option__label">Sensitivity</span>
          <span class="quiz-option__desc">Redness, reactive skin, or broken barrier</span>
        </button>
      </div>
    </div>

    <!-- Step 2: Skin type -->
    <div class="quiz-step" data-quiz-step="2">
      <p class="quiz-step__label">Step 2 of 4</p>
      <h2 class="quiz-step__question">How would you describe your <em>skin type</em>?</h2>
      <div class="quiz-options">
        <button class="quiz-option" data-quiz-option data-value="oily">
          <span class="quiz-option__icon">🫧</span>
          <span class="quiz-option__label">Oily</span>
          <span class="quiz-option__desc">Shiny T-zone or all-over shine by midday</span>
        </button>
        <button class="quiz-option" data-quiz-option data-value="dry">
          <span class="quiz-option__icon">🌾</span>
          <span class="quiz-option__label">Dry</span>
          <span class="quiz-option__desc">Feels tight, flaky, or rough to the touch</span>
        </button>
        <button class="quiz-option" data-quiz-option data-value="combination">
          <span class="quiz-option__icon">☯️</span>
          <span class="quiz-option__label">Combination</span>
          <span class="quiz-option__desc">Oily T-zone with normal or dry cheeks</span>
        </button>
        <button class="quiz-option" data-quiz-option data-value="normal">
          <span class="quiz-option__icon">⚖️</span>
          <span class="quiz-option__label">Normal</span>
          <span class="quiz-option__desc">Balanced skin with minimal sensitivity</span>
        </button>
        <button class="quiz-option" data-quiz-option data-value="sensitive">
          <span class="quiz-option__icon">🌱</span>
          <span class="quiz-option__label">Sensitive</span>
          <span class="quiz-option__desc">Reactive, easily irritated, prone to redness</span>
        </button>
      </div>
      <div class="quiz-nav">
        <button class="quiz-back" data-quiz-back>← Back</button>
      </div>
    </div>

    <!-- Step 3: Routine -->
    <div class="quiz-step" data-quiz-step="3">
      <p class="quiz-step__label">Step 3 of 4</p>
      <h2 class="quiz-step__question">What's your current <em>skincare routine</em>?</h2>
      <div class="quiz-options">
        <button class="quiz-option" data-quiz-option data-value="minimal">
          <span class="quiz-option__icon">⚡</span>
          <span class="quiz-option__label">Minimal</span>
          <span class="quiz-option__desc">1–2 products. Quick and simple is best.</span>
        </button>
        <button class="quiz-option" data-quiz-option data-value="standard">
          <span class="quiz-option__icon">🌿</span>
          <span class="quiz-option__label">Standard</span>
          <span class="quiz-option__desc">3–4 products. A considered daily ritual.</span>
        </button>
        <button class="quiz-option" data-quiz-option data-value="extensive">
          <span class="quiz-option__icon">🧬</span>
          <span class="quiz-option__label">Extensive</span>
          <span class="quiz-option__desc">5+ products. Skincare is a passion.</span>
        </button>
      </div>
      <div class="quiz-nav">
        <button class="quiz-back" data-quiz-back>← Back</button>
      </div>
    </div>

    <!-- Step 4: Priority -->
    <div class="quiz-step" data-quiz-step="4">
      <p class="quiz-step__label">Step 4 of 4</p>
      <h2 class="quiz-step__question">What matters most to you in a <em>serum</em>?</h2>
      <div class="quiz-options">
        <button class="quiz-option" data-quiz-option data-value="efficacy">
          <span class="quiz-option__icon">🎯</span>
          <span class="quiz-option__label">Proven Efficacy</span>
          <span class="quiz-option__desc">Clinical results I can see and measure</span>
        </button>
        <button class="quiz-option" data-quiz-option data-value="texture">
          <span class="quiz-option__icon">🕊️</span>
          <span class="quiz-option__label">Texture &amp; Feel</span>
          <span class="quiz-option__desc">Lightweight, fast-absorbing, no residue</span>
        </button>
        <button class="quiz-option" data-quiz-option data-value="natural">
          <span class="quiz-option__icon">🌍</span>
          <span class="quiz-option__label">Natural Ingredients</span>
          <span class="quiz-option__desc">Plant-derived, clean, no synthetics</span>
        </button>
        <button class="quiz-option" data-quiz-option data-value="value">
          <span class="quiz-option__icon">✦</span>
          <span class="quiz-option__label">Value</span>
          <span class="quiz-option__desc">Best formulation for the investment</span>
        </button>
      </div>
      <div class="quiz-nav">
        <button class="quiz-back" data-quiz-back>← Back</button>
      </div>
    </div>

    <!-- Results -->
    <div class="quiz-results" data-quiz-results>
      <div class="quiz-results__header">
        <p class="t-eyebrow">Your formula</p>
        <h2 class="quiz-results__title">Your skin, <em style="font-family: var(--font-serif); font-style: italic; color: var(--c-green-nat);">answered.</em></h2>
        <p class="quiz-results__sub">Based on your answers, we've identified these formulas as your best match.</p>
      </div>

      <div class="quiz-results__products" data-quiz-results-grid>
        <!-- Populated by JS -->
      </div>

      <div class="quiz-restart">
        <button class="btn btn--outline" data-quiz-restart>Retake the Quiz</button>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Serum Finder Quiz",
  "settings": [],
  "presets": [
    { "name": "Serum Finder Quiz" }
  ]
}
{% endschema %}
