{%- liquid
  assign collection = section.settings.collection
  if collection == blank
    assign collection = collections['all']
  endif
  assign products = collection.products | limit: section.settings.products_to_show
-%}

<section class="featured-collection section">
  <div class="container">
    <div class="section-header">
      <div class="section-header__left">
        {%- if section.settings.label != blank -%}
          <p class="t-label section-header__label reveal">{{ section.settings.label }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="t-h2 section-header__title reveal reveal-delay-1">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="section-header__sub reveal reveal-delay-2">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.cta_label != blank -%}
        <div class="section-header__right reveal reveal-delay-2">
          <a href="{{ section.settings.cta_url | default: collection.url }}" class="btn btn--outline">
            {{ section.settings.cta_label }}
          </a>
        </div>
      {%- endif -%}
    </div>

    <div class="products-grid">
      {%- for product in products -%}
        {% render 'product-card', product: product, index: forloop.index %}
      {%- else -%}
        {%- for i in (1..8) -%}
          <div class="product-card">
            <div class="product-card__media">
              {{ 'product-' | append: i | placeholder_svg_tag: 'product-card__placeholder' }}
            </div>
            <div class="product-card__info">
              <p class="product-card__category">Serum</p>
              <p class="product-card__name">Sample Product {{ i }}</p>
              <div class="product-card__footer">
                <span class="product-card__price">£48.00</span>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "The Collection"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "The Serums"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Eight targeted formulas. One clear skin philosophy."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to show"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4,
      "max": 12,
      "step": 2,
      "default": 8
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection",
      "settings": {
        "label": "The Collection",
        "title": "The Serums",
        "subtitle": "Eight targeted formulas. One clear skin philosophy.",
        "products_to_show": 8,
        "cta_label": "View All Serums"
      }
    }
  ]
}
{% endschema %}
