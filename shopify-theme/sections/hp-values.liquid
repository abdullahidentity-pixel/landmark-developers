<section class="hp-values section">
  <div class="container">
    <div class="hp-values__layout reveal">

      <!-- Background image column -->
      <div class="hp-values__image-col">
        {%- if section.settings.bg_image != blank -%}
          {{- section.settings.bg_image | image_url: width: 1200 | image_tag:
              loading: 'lazy',
              alt: section.settings.bg_image.alt | default: 'Brand values',
              class: 'hp-values__bg-img' -}}
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'hp-values__bg-img' }}
        {%- endif -%}
        <div class="hp-values__image-overlay"></div>
      </div>

      <!-- Values panel -->
      <div class="hp-values__panel">
        {%- if section.settings.label != blank -%}
          <span class="hp-values__label">{{ section.settings.label }}</span>
        {%- endif -%}
        <h2 class="hp-values__title">{{ section.settings.title }}</h2>

        <ul class="hp-values__list">
          {%- for block in section.blocks -%}
            <li class="hp-value-item" {{ block.shopify_attributes }}>
              <div class="hp-value-item__header">
                <span class="hp-value-item__name">{{ block.settings.name }}</span>
                <span class="hp-value-item__number">0{{ forloop.index }}</span>
              </div>
              {%- if block.settings.description != blank -%}
                <p class="hp-value-item__desc">{{ block.settings.description }}</p>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>

        {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
          <a href="{{ section.settings.cta_url }}" class="hp-values__cta">
            {{ section.settings.cta_label }} →
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "HP — Brand Values",
  "tag": "section",
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Value name",
          "default": "Simplicity"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Clean formulas, clear labels, no confusion."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Panel label",
      "default": "What We Stand For"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Panel title",
      "default": "Four principles. Every formula."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "About Velour Skin"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "presets": [
    {
      "name": "HP — Brand Values",
      "settings": {
        "label": "What We Stand For",
        "title": "Four principles. Every formula.",
        "cta_label": "About Velour Skin"
      },
      "blocks": [
        {
          "type": "value",
          "settings": {
            "name": "Simplicity",
            "description": "Clean formulas, clear labels, no confusion."
          }
        },
        {
          "type": "value",
          "settings": {
            "name": "Efficacy",
            "description": "Actives at proven concentrations. No aesthetic-only ingredients."
          }
        },
        {
          "type": "value",
          "settings": {
            "name": "Transparency",
            "description": "Full ingredient disclosure. We explain what every component does."
          }
        },
        {
          "type": "value",
          "settings": {
            "name": "Consistency",
            "description": "Results come from ritual. We design for real life, not shelf display."
          }
        }
      ]
    }
  ]
}
{% endschema %}
