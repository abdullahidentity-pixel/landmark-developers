[
  {
    "name": "theme_info",
    "theme_name": "Velour Skin",
    "theme_version": "1.0.0",
    "theme_author": "Velour Skin",
    "theme_documentation_url": "",
    "theme_support_url": ""
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      },
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_max_width",
        "min": 60,
        "max": 300,
        "step": 10,
        "unit": "px",
        "label": "Logo max width",
        "default": 160
      }
    ]
  },
  {
    "name": "Colours",
    "settings": [
      {
        "type": "paragraph",
        "content": "The Velour Skin colour palette is hardcoded for brand consistency. These settings allow minor overrides for accent tones only."
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent colour",
        "default": "#49724a"
      },
      {
        "type": "color",
        "id": "color_accent_alt",
        "label": "Accent colour (light)",
        "default": "#cde8c9"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "drawer", "label": "Side drawer" },
          { "value": "page", "label": "Cart page" }
        ],
        "default": "drawer"
      },
      {
        "type": "checkbox",
        "id": "cart_show_gift_note",
        "label": "Show gift note field",
        "default": false
      }
    ]
  },
  {
    "name": "Social",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram handle",
        "info": "Enter without the @ symbol"
      },
      {
        "type": "text",
        "id": "social_tiktok",
        "label": "TikTok handle"
      },
      {
        "type": "text",
        "id": "social_pinterest",
        "label": "Pinterest handle"
      }
    ]
  },
  {
    "name": "SEO",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_breadcrumbs",
        "label": "Show breadcrumbs",
        "default": true
      }
    ]
  }
]
