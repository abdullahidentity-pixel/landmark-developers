{%- comment -%}
  REASSURANCE BADGES
  Usage: {% render 'reassurance-badges', variant: 'strip' %}
  variant: 'strip'  → full-width banner row (homepage, collection)
  variant: 'inline' → compact flex row (product page trust section)
{%- endcomment -%}

{%- assign _variant = variant | default: 'strip' -%}

{%- if _variant == 'strip' -%}
<div class="reassurance-strip reveal">
  <div class="reassurance-strip__inner">
{%- else -%}
<div class="reassurance-badges--inline">
{%- endif -%}

    <div class="reassurance-badge">
      <svg class="reassurance-badge__icon" width="20" height="20" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
           aria-hidden="true">
        <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/>
        <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
      </svg>
      <span class="reassurance-badge__text">Lightweight textures</span>
    </div>

    <div class="reassurance-badge">
      <svg class="reassurance-badge__icon" width="20" height="20" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
           aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <polyline points="12 6 12 12 16 14"/>
      </svg>
      <span class="reassurance-badge__text">Routine-friendly formulas</span>
    </div>

    <div class="reassurance-badge">
      <svg class="reassurance-badge__icon" width="20" height="20" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
           aria-hidden="true">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      <span class="reassurance-badge__text">Skin-focused formulas</span>
    </div>

    <div class="reassurance-badge">
      <svg class="reassurance-badge__icon" width="20" height="20" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
           aria-hidden="true">
        <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
        <line x1="1" y1="10" x2="23" y2="10"/>
      </svg>
      <span class="reassurance-badge__text">Secure checkout</span>
    </div>

{%- if _variant == 'strip' -%}
  </div>
</div>
{%- else -%}
</div>
{%- endif -%}
