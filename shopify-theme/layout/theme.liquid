<!doctype html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#142b1b">

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
  {%- endif -%}

  <!-- Canonical + OG -->
  <link rel="canonical" href="{{ canonical_url }}">
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:title" content="{{ page_title | escape }}">
  <meta property="og:type" content="website">
  {%- if page_image -%}
    <meta property="og:image" content="{{ page_image | image_url: width: 1200 }}">
    <meta property="og:image:width" content="1200">
  {%- endif -%}
  {%- if page_description -%}
    <meta property="og:description" content="{{ page_description | escape }}">
  {%- endif -%}

  <!-- Google Fonts: DM Sans + Playfair Display -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style"
    href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300;1,9..40,400&family=Playfair+Display:ital,wght@0,400;1,400;1,500&display=swap">
  <link rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300;1,9..40,400&family=Playfair+Display:ital,wght@0,400;1,400;1,500&display=swap">

  <!-- Theme CSS -->
  {{ 'theme.css' | asset_url | stylesheet_tag }}

  <!-- Shopify required -->
  {{ content_for_header }}

  <script>
    document.documentElement.classList.replace('no-js', 'js');
  </script>
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">

  <a class="visually-hidden" href="#main-content">Skip to content</a>

  <!-- Screen reader live region — cart announcements -->
  <div id="cart-live-region" aria-live="polite" aria-atomic="true"></div>

  <!-- Cart overlay (behind drawer) -->
  <div id="cart-overlay" class="cart-overlay" aria-hidden="true"></div>

  <!-- Cart drawer -->
  <div id="cart-drawer" class="cart-drawer" role="dialog" aria-label="Shopping cart" aria-hidden="true">
    <div class="cart-drawer__header">
      <div>
        <p class="cart-drawer__title">Your Ritual</p>
        <p class="cart-drawer__count"><span data-cart-count>0</span> items</p>
      </div>
      <button id="cart-drawer-close" class="cart-drawer__close" aria-label="Close cart">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <path d="M1 1l16 16M17 1L1 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <div class="cart-drawer__body" id="cart-items">
      <div class="cart-drawer__empty">
        <p>Your ritual awaits.</p>
        <a href="/collections/all" class="btn btn--primary btn--sm">Explore Serums</a>
      </div>
    </div>

    <div class="cart-drawer__footer">
      <div class="cart-subtotal">
        <span class="cart-subtotal__label">Subtotal</span>
        <span class="cart-subtotal__price" id="cart-subtotal">£0.00</span>
      </div>
      <p class="cart-shipping-note">Free shipping on orders over £60 · Taxes calculated at checkout</p>
      <a href="/checkout" class="btn--checkout">Proceed to Checkout</a>
      <button class="btn--continue" onclick="window.cartDrawer.close()">Continue Shopping</button>
    </div>
  </div>

  <!-- Mobile navigation -->
  <div class="mobile-menu" role="dialog" aria-label="Navigation" aria-hidden="true">
    <div class="mobile-menu__inner">
      <div class="mobile-menu__header">
        <a href="/" class="footer-logo">{{ shop.name }}</a>
        <button class="mobile-menu__close site-header__icon-btn" aria-label="Close menu">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M1 1l18 18M19 1L1 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>

      <nav class="mobile-menu__nav" aria-label="Mobile navigation">
        <a href="/collections/serums" class="mobile-menu__nav-link">Serums</a>
        <a href="/collections/all" class="mobile-menu__nav-link">All Products</a>
        <a href="/pages/routine" class="mobile-menu__nav-link">Routine</a>
        <a href="/pages/ingredients" class="mobile-menu__nav-link">Science</a>
        <a href="/pages/quiz" class="mobile-menu__nav-link">Skin Quiz</a>
        <a href="/pages/about" class="mobile-menu__nav-link">About</a>
        <a href="/pages/contact" class="mobile-menu__nav-link">Contact</a>
      </nav>

      <div class="mobile-menu__footer">
        <a href="/account" class="btn btn--outline btn--sm">Account</a>
      </div>
    </div>
  </div>

  {%- sections 'announcement-bar' -%}
  {%- sections 'header' -%}

  <main id="main-content" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- sections 'footer' -%}

  <!-- Quick-add drawer overlay -->
  <div id="quick-add-overlay" aria-hidden="true"></div>

  <!-- Quick-add drawer — bottom sheet for product cards -->
  <div id="quick-add-drawer"
       class="quick-add-drawer"
       role="dialog"
       aria-label="Quick add to bag"
       aria-hidden="true">
    <div class="quick-add-drawer__handle" aria-hidden="true"></div>
    <button id="quick-add-drawer-close" class="quick-add-drawer__close" aria-label="Close">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
    <div class="quick-add-drawer__inner">
      <div class="quick-add-drawer__header">
        <div class="quick-add-drawer__image">
          <img src="" alt="" width="72" height="90" loading="lazy">
        </div>
        <div class="quick-add-drawer__meta">
          <h2 class="quick-add-drawer__title"></h2>
          <p class="quick-add-drawer__tagline"></p>
          <p class="quick-add-drawer__price"></p>
        </div>
      </div>
      <div class="quick-add-drawer__footer">
        <button
          class="quick-add-drawer__submit"
          data-quick-add-submit
          aria-label="Add to bag">
          Add to Bag
        </button>
        <a href="#" class="quick-add-drawer__link btn btn--outline btn--sm" aria-label="View full product details">
          View Details
        </a>
      </div>
    </div>
  </div>

  <!-- Sticky ATC bar — shown on product pages when ATC scrolls out of view -->
  {%- if template.name == 'product' -%}
  <div class="sticky-atc" id="sticky-atc" aria-hidden="true">
    <div class="sticky-atc__inner">
      <div class="sticky-atc__product">
        <div class="sticky-atc__thumb">
          {%- if product.featured_media -%}
            {{- product.featured_media | image_url: width: 120
                | image_tag:
                  loading: 'lazy',
                  alt: product.title,
                  width: 48,
                  height: 60 -}}
          {%- endif -%}
        </div>
        <div class="sticky-atc__info">
          <p class="sticky-atc__name">{{ product.title }}</p>
          <p class="sticky-atc__price">{{ product.selected_or_first_available_variant.price | money }}</p>
        </div>
      </div>
      <div class="sticky-atc__actions">
        <button class="sticky-atc__btn"
                {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
                aria-label="Add {{ product.title }} to bag">
          {%- if product.selected_or_first_available_variant.available -%}
            Add to Bag
          {%- else -%}
            Sold Out
          {%- endif -%}
        </button>
      </div>
    </div>
  </div>
  {%- endif -%}

  <!-- Velour Skin upsell config — set variant IDs to match your store -->
  <script>
    window.velourUpsells = [
      {%- if product != blank -%}
        {%- assign cream = all_products['velour-skin-barrier-cream'] -%}
        {%- assign spray = all_products['velour-skin-hydrating-mist'] -%}
        {%- if cream != blank and cream.handle != product.handle -%}
          {
            variantId: {{ cream.first_available_variant.id | json }},
            title: {{ cream.title | json }},
            desc: "Barrier support · Daily moisturiser",
            price: {{ cream.first_available_variant.price }},
            image: {{ cream.featured_media | image_url: width: 120 | json }}
          },
        {%- endif -%}
        {%- if spray != blank and spray.handle != product.handle -%}
          {
            variantId: {{ spray.first_available_variant.id | json }},
            title: {{ spray.title | json }},
            desc: "Hydrating mist · Refreshes actives",
            price: {{ spray.first_available_variant.price }},
            image: {{ spray.featured_media | image_url: width: 120 | json }}
          }
        {%- endif -%}
      {%- endif -%}
    ].filter(Boolean);
  </script>

  <!-- Theme JS -->
  <script src="{{ 'theme.js' | asset_url }}" defer></script>

</body>
</html>
